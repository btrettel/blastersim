m_spring     = 10.0    ! g
p_fs_plunger = 4.0     ! kPa
p_fd_plunger = 1.0     ! kPa

! atmosphere
p_atm    = 100.0 ! kPa (optional, absolute)
temp_atm = 310.0 ! K (optional)

! flow restriction
d_e = 5.0e-3 ! m
b   = 0.528  ! unitless (optional)

! Experimental result
actual_v_muzzle = 60.0 ! m/s (optional)
